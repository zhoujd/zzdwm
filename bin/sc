#!/bin/sh

tmpfile=$(mktemp /tmp/screen-pipe.XXXXXX)
trap 'rm "$tmpfile"' 0 1 15
cat > "$tmpfile" <<EOF
escape \`\`
startup_message off
bell_msg ""
vbell_msg ""
bell off
vbell off
altscreen on
defutf8 on
deflogin off
defflow off
defshell -bash
term screen-256color
termcapinfo st* ti@:te@
bind ^h
bind h
bind ^Q
bind q
bind ^S
bind s
bind ^X
bind x
bind ^Z
bind z
EOF
screen -c "$tmpfile" $@

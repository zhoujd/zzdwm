#!/bin/sh

tmpfile=$(mktemp /tmp/screen-pipe.XXXXXX)
trap 'rm -f "$tmpfile"' 0 1 15
cat > "$tmpfile" <<EOF
escape \`\`
startup_message off
bell_msg ""
vbell_msg ""
bell off
vbell off
nonblock on
altscreen on
maptimeout 0
msgwait 3
msgminwait 0
defutf8 on
deflogin off
defflow off
defscrollback 5000
defdynamictitle on
defshell -$SHELL
term screen-256color
termcapinfo st*|rxvt* ti@:te@
bind ^G
bind g
bind ^H
bind h
bind ^Q
bind q
bind ^S
bind s
bind ^X
bind x
bind ^Z
bind z
hardstatus off
hardstatus string "%n %t"
windowlist string "%4n %t %h%=%f"
EOF
if [ -n "$STY" ]; then
   exec screen ${@:-1}
else
   exec screen -c "$tmpfile" $@
fi

#!/bin/sh

FIFO="/tmp/dvtm-status.$$"
trap 'rm -f "$FIFO"' 0 1 15

[ -p "$FIFO" ] || mkfifo -m 600 "$FIFO" || exit 1

mktime() {
    # If Sunday, show the week number of the next week
    if [ $(date +'%u') -gt 6 ]; then
        WEEK=$(date +'W%-V' -d "next Mon")
    else
        WEEK=$(date +'W%-V')
    fi
    TIME=$(date +'%a %-e %b %-l:%M %p')
    echo ${WEEK} ${TIME}
}

while true; do
    TZ="Asia/Shanghai" mktime
    sleep 20
done > "$FIFO" &

STATUS_PID=$!
dvtm -s "$FIFO" "$@" 2> /dev/null
kill $STATUS_PID
wait $STATUS_PID 2> /dev/null
